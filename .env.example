# Klucze z https://www.aftermarket.pl/API/Create/
AM_API_KEY=
AM_API_SECRET=

# Opcjonalne nadpisanie URL (domyślnie https://json.aftermarket.pl)
# AM_API_URL=https://json.aftermarket.pl

# Timeout HTTP w ms (biblioteka ma 1000, my podnosimy)
AM_TIMEOUT_MS=15000

# Ścieżka do bazy SQLite (domyślnie ./data/aftermarket.db)
# AM_DB_PATH=

# ===== Moz Links API =====
# Z https://moz.com/products/api -> Manage Tokens
MOZ_TOKEN=

# ===== Google Search Console =====
# 1. https://console.cloud.google.com/apis/credentials -> Create OAuth 2.0 Client ID
#    Application type: Desktop application
# 2. Wklej client_id i client_secret poniżej
# 3. Uruchom: npm run gsc:auth (przeglądarka się otworzy, refresh_token zapisze się automatycznie)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
